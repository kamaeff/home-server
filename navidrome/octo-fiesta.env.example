ASPNETCORE_ENVIRONMENT=Production
Library__DownloadPath=/app/downloads


# ===== SUBSONIC SETTINGS =====
# Navidrome/Subsonic server URL
Subsonic__Url=http://navidrome:4533
Subsonic__MusicService=SquidWTF
Subsonic__StorageMode=Permanent
Subsonic__EnableExternalPlaylists=true
Subsonic__PlaylistsDirectory=playlists
Subsonic__ExplicitFilter=ExplicitOnly
# Track or Album
Subsonic__DownloadMode=Track
Subsonic__AutoUpgradeQuality=true

# ===== SQUIDWTF SETTINGS =====
# Qobuz or Tidal
SquidWTF__Source=Tidal
# Preferred audio quality (optional)
# Qobuz: 27 (FLAC 24-bit/192kHz), 7 (FLAC 24-bit/96kHz), 6 (FLAC 16-bit/44kHz), 5 (MP3 320kbps)
# Tidal: HI_RES_LOSSLESS (FLAC 24-bit/192kHz), LOSSLESS (FLAC 16-bit/44kHz), HIGH (AAC 320kbps), LOW (AAC 96kbps)
SquidWTF__Quality=HIGH
# Instance timeout in seconds for Tidal backend (default: 5)
# Switches to next instance if current one doesn't respond in time
SquidWTF__InstanceTimeoutSeconds=5



# ===== NOT IN USE SUBSONIC SETTINGS =====
Subsonic__CacheDurationHours=1

# ===== NOT IN USE DEEZER SETTINGS =====
Deezer__Arl=
Deezer__ArlFallback=
# Preferred audio quality: FLAC, MP3_320, MP3_128 (optional, defaults to highest available)
Deezer__Quality=

# ===== NOT IN USE QOBUZ SETTINGS =====
Qobuz__UserAuthToken=
Qobuz__UserId=
# Preferred audio quality: FLAC, FLAC_24_HIGH, FLAC_24_LOW, FLAC_16, MP3_320 (optional)
Qobuz__Quality=
