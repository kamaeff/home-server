(tls) {
    tls {
        dns cloudflare {$CLOUDFLARE_API_TOKEN}
        resolvers 1.1.1.1
    }
}

vw.{$SERVICE_DOMAIN} {
    import tls
    reverse_proxy vw:80
}

drive.{$SERVICE_DOMAIN} {
    import tls
    reverse_proxy http://copyparty:3923
}

music.{$SERVICE_DOMAIN} {
    import tls
    handle_path /picard/* {
        reverse_proxy picard:5800
    }
    reverse_proxy navidrome-octo-fiesta:5274
}

