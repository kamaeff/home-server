(tls) {
    tls {
        dns cloudflare {$CLOUDFLARE_API_TOKEN}
        resolvers 1.1.1.1
    }
}

vw.{$SERVICE_DOMAIN} {
    import tls
    reverse_proxy vw:80
}

drive.{$SERVICE_DOMAIN} {
    import tls
    reverse_proxy copyparty:3923
}

